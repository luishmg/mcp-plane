# Plane MCP Server Configuration
# Generate a token in Plane: Profile Settings -> API Tokens

# --- REQUIRED ---
PLANE_MCP_TOKEN=plane_api_your_token_here

# --- Plane API ---
PLANE_API_BASE=http://umbrel:8762

# --- Server ---
HOST=127.0.0.1
PORT=8763
# Comma-separated list of allowed Origin values for the MCP endpoint.
# Leave empty to skip origin enforcement (relies on loopback binding).
ALLOWED_ORIGINS=

# --- Limits ---
REQUEST_TIMEOUT_SECONDS=15
RATE_LIMIT_PER_MINUTE=60
